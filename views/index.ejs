<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Recom Place</title>
    
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    
    <!-- Tailwind CSS CDN (v3 Play) -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              sans: ['Inter', 'sans-serif'],
            },
            colors: {
              brand: '#FFC81E',
            }
          }
        }
      }
    </script>

    <script>
      // Prevent stale service workers from breaking CDN fetches under CSP.
      if ("serviceWorker" in navigator) {
        navigator.serviceWorker
          .getRegistrations()
          .then(async (registrations) => {
            if (!registrations.length) return;
            if (sessionStorage.getItem("sw-cleared") === "1") return;

            sessionStorage.setItem("sw-cleared", "1");
            await Promise.all(registrations.map((reg) => reg.unregister()));

            if (navigator.serviceWorker.controller) {
              location.reload();
            }
          })
          .catch(() => {});
      }
    </script>

    <style>
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb { background: #000000; border-radius: 10px; }
      
      @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .animate-fade {
        animation: fadeIn 0.4s ease-out forwards;
      }

      @keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
      }
      .animate-spin {
        animation: spin 1s linear infinite;
      }

      .btn-like.active i {
        color: #ef4444;
      }
      .btn-like.active {
        border-color: #fee2e2;
        background-color: #fef2f2;
      }
    </style>
  </head>
  <body class="bg-white text-black font-sans antialiased selection:bg-brand selection:text-black">
    
    <!-- Background Gradient -->
    <div class="fixed inset-0 -z-10 bg-[radial-gradient(circle_at_bottom,_var(--tw-gradient-stops))] from-brand/10 via-transparent to-transparent pointer-events-none"></div>
    
    <!-- Navigation -->
    <nav class="sticky top-0 z-50 w-full bg-gradient-to-t from-brand/20 via-white/90 to-white/95 backdrop-blur-md border-b border-black/5">
      <div class="max-w-6xl mx-auto px-6">
        <div class="flex justify-center sm:justify-between items-center h-16">
          <div class="flex items-center gap-2">
            <div class="w-8 h-8 bg-brand rounded-lg flex items-center justify-center text-black shadow-sm shadow-brand/20">
              <i class="fa-solid fa-utensils text-sm"></i>
            </div>
            <span class="text-sm font-bold tracking-tight uppercase">Recom Place</span>
          </div>
          
          <button 
            data-open-form
            class="hidden sm:flex h-10 px-6 bg-black text-white text-[11px] font-bold rounded-full hover:bg-slate-800 transition-all active:scale-95 items-center gap-2 shadow-lg shadow-black/5"
          >
            <i class="fa-solid fa-plus text-brand"></i>
            Add Recomendation
          </button>
        </div>
      </div>
    </nav>

    <!-- Floating Action Button (FAB) -->
    <button 
      data-open-form
      class="fixed bottom-8 right-8 z-[90] w-16 h-16 bg-black text-white rounded-full flex items-center justify-center shadow-2xl hover:bg-brand hover:text-black hover:scale-110 active:scale-95 transition-all duration-300 group"
      aria-label="Add Recommendation"
    >
      <i class="fa-solid fa-plus text-xl transition-transform group-hover:rotate-90"></i>
    </button>

    <main class="max-w-6xl mx-auto px-6 py-12 lg:py-20">
      
      <!-- Hero -->
      <div class="mb-16">
        <div class="flex items-center gap-2 mb-4">
           <span class="px-2 py-0.5 bg-brand/10 text-black text-[9px] font-bold uppercase tracking-widest rounded">Community Curated</span>
        </div>
        <h2 class="text-2xl sm:text-4xl lg:text-5xl font-extrabold text-black tracking-tight leading-tight mb-4">
          Cari tempat Nongki? Makan? atau apapun itu yang <span class="text-brand">pas</span><br class="hidden sm:block"/> di kantong & selera. <br>
          <span class="text-brand text-xl sm:text-4xl lg:text-5xl">Bagikan juga tempat langganan mu !!!</span>
        </h2>
       
      </div>

      <!-- Filters Bar -->
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-6 mb-12">
        <div class="flex items-center gap-1 p-1 bg-black/[0.03] rounded-xl border border-black/5 overflow-x-auto max-w-full scrollbar-hide">
          <a href="/?category=semua" 
             class="whitespace-nowrap px-4 py-1.5 rounded-lg text-[11px] font-bold transition-all <%= activeCategory === 'semua' ? 'bg-brand text-black shadow-sm' : 'text-black/40 hover:text-black' %>">
            Semua
          </a>
          <% ['murah', 'standard', 'mahal'].forEach(cat => { %>
            <a href="/?category=<%= cat %>" 
               class="whitespace-nowrap px-4 py-1.5 rounded-lg text-[11px] font-bold transition-all capitalize <%= activeCategory === cat ? 'bg-brand text-black shadow-sm' : 'text-black/40 hover:text-black' %>">
              <%= cat %>
            </a>
          <% }) %>
        </div>
        
        <div class="text-[9px] font-bold text-black/20 uppercase tracking-[0.2em] sm:block hidden">
          Found <span class="text-black/60"><%= totalRecommendations %></span> options
        </div>
      </div>

      <!-- Cards Grid -->
      <% if (recommendations.length === 0) { %>
        <div class="py-32 border border-dashed border-black/10 rounded-[2.5rem] bg-black/[0.01] text-center animate-fade">
          <i class="fa-solid fa-cookie-bite text-3xl text-black/5 mb-4"></i>
          <p class="text-sm font-semibold text-black/30 tracking-tight">Belum ada data di kategori ini.</p>
        </div>
      <% } else { %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-12">
          <% recommendations.forEach((item, index) => { %>
            <article class="group flex flex-col animate-fade opacity-0 border border-brand rounded-[2.5rem] p-5 bg-white hover:shadow-xl hover:shadow-brand/5 transition-all duration-500" style="animation-delay: <%= 0.05 * (index % 6) %>s">
              <!-- Thumbnail -->
              <div class="relative aspect-[4/3] overflow-hidden rounded-3xl mb-6 bg-black/[0.02] border border-black/5">
                <% if (item.has_image) { %>
                  <img 
                    src="<%= item.foto_url %>" 
                    alt="<%= item.nama_tempat %>"
                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                    loading="lazy"
                  />
                <% } else { %>
                  <div class="w-full h-full flex flex-col items-center justify-center text-black/5 group-hover:text-brand/20 transition-colors duration-500">
                    <i class="fa-solid fa-utensils text-5xl"></i>
                  </div>
                <% } %>
                
                <div class="absolute top-5 left-5">
                  <span class="px-3 py-1.5 rounded-xl text-[9px] font-bold uppercase tracking-widest text-black bg-brand shadow-sm">
                    <%= item.kategori %>
                  </span>
                </div>
              </div>

              <!-- Info Section -->
              <div class="flex flex-col flex-grow px-1">
                <div class="flex justify-between items-start gap-4 mb-3">
                  <h3 class="text-xl font-bold text-black leading-tight group-hover:text-brand transition-colors duration-300">
                    <%= item.nama_tempat %>
                  </h3>
                  <% if (item.formatted_price) { %>
                    <span class="shrink-0 px-2 py-1 bg-black text-white text-[10px] font-bold rounded-md">
                      <%= item.formatted_price %>
                    </span>
                  <% } %>
                </div>

                <% if (item.nama_menu) { %>
                  <p class="text-[14px] font-semibold text-black/50 mb-3 flex items-center gap-2">
                    <span class="w-1.5 h-1.5 bg-brand rounded-full"></span>
                    <%= item.nama_menu %>
                  </p>
                <% } %>

                <% if (item.deskripsi) { %>
                  <p class="text-[13px] text-black/60 leading-relaxed mb-6 line-clamp-3 italic font-medium">
                    "<%= item.deskripsi %>"
                  </p>
                <% } %>

                <!-- Like Button (NEW POSITION) -->
                <div class="mb-6">
                  <button 
                    class="btn-like flex items-center gap-2 px-4 py-2 border border-black/5 rounded-xl hover:bg-red-50 hover:border-red-100 transition-all group/like"
                    data-id="<%= item.id %>"
                  >
                    <i class="fa-solid fa-heart text-black/20 group-hover/like:text-red-400 transition-colors"></i>
                    <span class="text-[11px] font-bold text-black/40 likes-count"><%= item.likes || 0 %></span>
                    <span class="text-[9px] font-bold text-black/20 uppercase tracking-widest ml-1">Suka</span>
                  </button>
                </div>

                <!-- Buttons & Meta -->
                <div class="mt-auto space-y-4">
                  <% if (item.google_maps_link) { %>
                    <a href="<%= item.google_maps_link %>" target="_blank" rel="noreferrer" 
                       class="flex items-center justify-center gap-2 w-full py-3.5 bg-brand text-black rounded-2xl text-[11px] font-bold uppercase tracking-widest hover:bg-black hover:text-brand transition-all duration-300 shadow-sm shadow-brand/10 active:scale-[0.98]">
                      <i class="fa-solid fa-location-dot"></i>
                      <span>Lihat Lokasi</span>
                    </a>
                  <% } %>

                  <div class="pt-4 border-t border-black/5 flex items-center justify-between">
                    <div class="flex items-center gap-2">
                      <div class="w-6 h-6 rounded-full bg-black/[0.03] flex items-center justify-center">
                         <i class="fa-solid fa-user text-[9px] text-black/20"></i>
                      </div>
                      <p class="text-[10px] text-black/40 uppercase tracking-tight">
                        Direkomendasikan Oleh: <span class="font-black text-black"><%= (item.created_by || "Anonim").toUpperCase() %></span>
                      </p>
                    </div>
                    <span class="text-[9px] font-bold text-black/10 uppercase tracking-tighter"><%= item.formatted_date.split(' ').slice(0, 3).join(' ') %></span>
                  </div>
                </div>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    </main>

    <!-- Footer -->
    <footer class="py-12 border-t border-black/5">
      <div class="max-w-6xl mx-auto px-6 text-center">
        <p class="text-[10px] font-bold text-black/30 uppercase tracking-[0.2em]">
          This Website Created by <span class="text-black">Rio Puji Nugroho</span> &copy; Rio
        </p>
      </div>
    </footer>

    <!-- Modal Form -->
    <div id="form-modal" class="<%= shouldOpenForm ? '' : 'hidden' %> fixed inset-0 z-[100] overflow-y-auto" role="dialog" aria-modal="true">
      <div class="flex items-center justify-center min-h-screen p-4 sm:p-6">
        <div data-close-form class="fixed inset-0 bg-black/60 backdrop-blur-md transition-opacity"></div>

        <div class="relative bg-white rounded-[2rem] sm:rounded-[3rem] overflow-hidden max-w-2xl w-full shadow-2xl animate-fade">
          <div class="p-6 sm:p-10 lg:p-12">
            <div class="flex justify-between items-start mb-8">
              <div>
                <h3 class="text-2xl font-black text-black tracking-tight">Tambah Rekomendasi</h3>
                <p class="text-[11px] font-bold text-black/40 uppercase tracking-[0.2em] mt-1">Bagikan tempat favoritmu</p>
              </div>
              <button data-close-form class="w-10 h-10 rounded-full bg-black/5 text-black/40 flex items-center justify-center hover:bg-black hover:text-white transition-all active:scale-90">
                <i class="fa-solid fa-xmark text-sm"></i>
              </button>
            </div>

            <form action="/rekomendasi" method="POST" class="space-y-8">
              <!-- Section: Basic Info -->
              <div class="space-y-5">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                  <div class="space-y-2">
                    <label for="nama_tempat" class="block text-[10px] font-black text-black uppercase tracking-widest ml-1">Nama Tempat *</label>
                    <div class="relative group">
                      <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                        <i class="fa-solid fa-store text-[10px] text-black/20 group-focus-within:text-brand transition-colors"></i>
                      </div>
                      <input type="text" id="nama_tempat" name="nama_tempat" required value="<%= formData.nama_tempat %>"
                             class="w-full pl-10 pr-4 py-4 bg-black/[0.03] border border-transparent focus:border-brand/30 focus:bg-white focus:ring-4 focus:ring-brand/5 rounded-2xl outline-none transition-all text-sm font-bold placeholder:text-black/20"
                             placeholder="Misal: Bubur Ayam Berkah" />
                    </div>
                  </div>

                  <div class="space-y-2">
                    <label for="created_by" class="block text-[10px] font-black text-black uppercase tracking-widest ml-1">Nama Kamu</label>
                    <div class="relative group">
                      <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                        <i class="fa-solid fa-user text-[10px] text-black/20 group-focus-within:text-brand transition-colors"></i>
                      </div>
                      <input type="text" id="created_by" name="created_by" value="<%= formData.created_by %>"
                             class="w-full pl-10 pr-4 py-4 bg-black/[0.03] border border-transparent focus:border-brand/30 focus:bg-white focus:ring-4 focus:ring-brand/5 rounded-2xl outline-none transition-all text-sm font-bold placeholder:text-black/20"
                             placeholder="Nama pemberi rekomendasi" />
                    </div>
                  </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                  <div class="space-y-2">
                    <label for="nama_menu" class="block text-[10px] font-black text-black uppercase tracking-widest ml-1">Menu Rekomendasi</label>
                    <div class="relative group">
                      <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                        <i class="fa-solid fa-utensils text-[10px] text-black/20 group-focus-within:text-brand transition-colors"></i>
                      </div>
                      <input type="text" id="nama_menu" name="nama_menu" value="<%= formData.nama_menu %>"
                             class="w-full pl-10 pr-4 py-4 bg-black/[0.03] border border-transparent focus:border-brand/30 focus:bg-white focus:ring-4 focus:ring-brand/5 rounded-2xl outline-none transition-all text-sm font-bold placeholder:text-black/20"
                             placeholder="Menu yang paling enak?" />
                    </div>
                  </div>

                  <div class="space-y-2">
                    <label for="price" class="block text-[10px] font-black text-black uppercase tracking-widest ml-1">Harga Menu</label>
                    <div class="relative group">
                      <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-sm font-bold text-black/20 group-focus-within:text-brand transition-colors">
                        Rp
                      </div>
                      <input type="text" id="price_display" name="price_display" value="<%= formData.price %>"
                             class="w-full pl-10 pr-4 py-4 bg-black/[0.03] border border-transparent focus:border-brand/30 focus:bg-white focus:ring-4 focus:ring-brand/5 rounded-2xl outline-none transition-all text-sm font-bold placeholder:text-black/20"
                             placeholder="0" />
                      <input type="hidden" name="price" id="price_hidden" value="<%= formData.price %>">
                    </div>
                  </div>
                </div>
              </div>

              <!-- Section: Category & Description -->
              <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
                <div class="space-y-2">
                  <label for="kategori" class="block text-[10px] font-black text-black uppercase tracking-widest ml-1">Range Harga *</label>
                  <div class="relative group">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                      <i class="fa-solid fa-tags text-[10px] text-black/20 group-focus-within:text-brand transition-colors"></i>
                    </div>
                    <select id="kategori" name="kategori" required
                            class="w-full pl-10 pr-10 py-4 bg-black/[0.03] border border-transparent focus:border-brand/30 focus:bg-white focus:ring-4 focus:ring-brand/5 rounded-2xl outline-none transition-all text-sm font-bold appearance-none cursor-pointer">
                      <option value="" disabled selected>Pilih...</option>
                      <% priceCategories.forEach(cat => { %>
                        <option value="<%= cat %>" <%= formData.kategori === cat ? "selected" : "" %>><%= cat.toUpperCase() %></option>
                      <% }) %>
                    </select>
                    <div class="absolute inset-y-0 right-0 pr-4 flex items-center pointer-events-none">
                      <i class="fa-solid fa-chevron-down text-[10px] text-black/20"></i>
                    </div>
                  </div>
                </div>

                <div class="md:col-span-2 space-y-2">
                  <label for="deskripsi" class="block text-[10px] font-black text-black uppercase tracking-widest ml-1">Review Singkat</label>
                  <div class="relative group">
                    <div class="absolute top-4 left-0 pl-4 pointer-events-none">
                      <i class="fa-solid fa-comment-dots text-[10px] text-black/20 group-focus-within:text-brand transition-colors"></i>
                    </div>
                    <textarea id="deskripsi" name="deskripsi" rows="1"
                              class="w-full pl-10 pr-4 py-4 bg-black/[0.03] border border-transparent focus:border-brand/30 focus:bg-white focus:ring-4 focus:ring-brand/5 rounded-2xl outline-none transition-all resize-none text-sm font-bold placeholder:text-black/20"
                              placeholder="Kenapa tempat ini recommended?"><%= formData.deskripsi %></textarea>
                  </div>
                </div>
              </div>

              <!-- Section: Links -->
              <div class="space-y-4 p-5 bg-brand/[0.03] rounded-[2rem] border border-brand/10">
                <div class="space-y-2">
                  <div class="flex items-center gap-2 mb-1">
                    <i class="fa-solid fa-map-location-dot text-brand text-[10px]"></i>
                    <label for="google_maps_link" class="block text-[10px] font-black text-black uppercase tracking-widest">Link Google Maps *</label>
                  </div>
                  <input type="url" id="google_maps_link" name="google_maps_link" required value="<%= formData.google_maps_link %>"
                         class="w-full px-5 py-4 rounded-2xl bg-white border border-black/5 focus:border-brand/30 outline-none transition-all text-[11px] font-bold shadow-sm"
                         placeholder="https://maps.google.com/..." />
                </div>
                
                <div class="space-y-2">
                  <div class="flex items-center gap-2 mb-1">
                    <i class="fa-solid fa-image text-brand text-[10px]"></i>
                    <label for="foto_url" class="block text-[10px] font-black text-black uppercase tracking-widest">Link Foto Unit (URL)</label>
                  </div>
                  <input type="url" id="foto_url" name="foto_url" value="<%= formData.foto_url %>"
                         class="w-full px-5 py-4 rounded-2xl bg-white border border-black/5 focus:border-brand/30 outline-none transition-all text-[11px] font-bold shadow-sm"
                         placeholder="https://images.unsplash.com/..." />
                </div>
              </div>

              <button type="submit" data-submit-btn
                      class="w-full py-5 bg-black text-white font-bold rounded-2xl hover:bg-brand hover:text-black transition-all text-[12px] uppercase tracking-[0.3em] shadow-xl shadow-black/10 active:scale-[0.98]">
                SIMPAN REKOMENDASI
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>

    <script>
      const modal = document.getElementById("form-modal");
      const openButtons = document.querySelectorAll("[data-open-form]");
      const closeButtons = document.querySelectorAll("[data-close-form]");
      const form = modal.querySelector("form");
      const submitBtn = modal.querySelector("[data-submit-btn]");
      const priceDisplay = document.getElementById("price_display");
      const priceHidden = document.getElementById("price_hidden");

      function openForm() {
        modal.classList.remove("hidden");
        document.body.classList.add("overflow-hidden");
      }

      function closeForm() {
        modal.classList.add("hidden");
        document.body.classList.remove("overflow-hidden");
      }

      openButtons.forEach(btn => btn.addEventListener("click", openForm));
      closeButtons.forEach(btn => btn.addEventListener("click", closeForm));

      // Auto-expand textarea
      const textarea = document.getElementById('deskripsi');
      if (textarea) {
        textarea.addEventListener('input', function() {
          this.style.height = 'auto';
          this.style.height = (this.scrollHeight) + 'px';
        });
      }

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && !modal.classList.contains("hidden")) closeForm();
      });

      function onlyDigits(value) {
        return (value || "").replace(/[^\d]/g, "");
      }

      function formatRupiahNumber(digits) {
        if (!digits) return "";
        const numberValue = Number(digits);
        if (!Number.isFinite(numberValue)) return "";
        return new Intl.NumberFormat("id-ID").format(numberValue);
      }

      function setFormattedPrice(nextDigits) {
        if (!priceHidden || !priceDisplay) return;
        priceHidden.value = nextDigits;
        priceDisplay.value = formatRupiahNumber(nextDigits);
      }

      function formatPriceWithCaret() {
        if (!priceDisplay || !priceHidden) return;
        const rawValue = priceDisplay.value;
        const selectionStart = priceDisplay.selectionStart ?? rawValue.length;
        const digitsLeftOfCaret = (rawValue.slice(0, selectionStart).match(/\d/g) || []).length;

        const digits = onlyDigits(rawValue);
        const formatted = formatRupiahNumber(digits);
        priceHidden.value = digits;

        priceDisplay.value = formatted;

        if (!formatted) return;

        let pos = 0;
        let digitCount = 0;
        while (pos < formatted.length && digitCount < digitsLeftOfCaret) {
          if (/\d/.test(formatted[pos])) digitCount += 1;
          pos += 1;
        }
        priceDisplay.setSelectionRange(pos, pos);
      }

      if (priceDisplay && priceHidden) {
        setFormattedPrice(onlyDigits(priceHidden.value || priceDisplay.value));

        priceDisplay.addEventListener("input", () => {
          formatPriceWithCaret();
        });

        priceDisplay.addEventListener("blur", () => {
          setFormattedPrice(onlyDigits(priceDisplay.value));
        });
      }

      if (form && submitBtn) {
        form.addEventListener("submit", () => {
          submitBtn.disabled = true;
          submitBtn.innerHTML =
            '<span class="inline-flex items-center justify-center gap-2">' +
            '<i class="fa-solid fa-spinner animate-spin"></i>' +
            "MENYIMPAN..." +
            "</span>";
        });
      }

      // Like Functionality
      const likeButtons = document.querySelectorAll('.btn-like');
      const userLikes = JSON.parse(localStorage.getItem('userLikes') || '{}');

      // Init UI based on localStorage
      likeButtons.forEach(btn => {
        const id = btn.getAttribute('data-id');
        if (userLikes[id]) {
          btn.classList.add('active', 'cursor-default');
          const icon = btn.querySelector('i');
          icon.classList.replace('text-black/20', 'text-red-500');
        }
      });

      likeButtons.forEach(btn => {
        btn.addEventListener('click', async () => {
          const id = btn.getAttribute('data-id');
          if (userLikes[id]) return;

          try {
            const response = await fetch(`/rekomendasi/${id}/like`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' }
            });

            const data = await response.json();
            if (data.success) {
              btn.classList.add('active', 'cursor-default');
              btn.querySelector('.likes-count').textContent = data.likes;
              const icon = btn.querySelector('i');
              icon.classList.replace('text-black/20', 'text-red-500');
              
              // Store in localStorage
              userLikes[id] = true;
              localStorage.setItem('userLikes', JSON.stringify(userLikes));
            }
          } catch (error) {
            console.error('Error liking:', error);
          }
        });
      });
    </script>
  </body>
</html>
